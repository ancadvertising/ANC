<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800&family=Poppins:wght@600&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --text-color: #ffffff;
            --highlight-color: #ffffff;
        }

        body {
            margin: 0;
            padding: 0;
            background: transparent;
            font-family: 'Montserrat', sans-serif;
            overflow: hidden; 
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            text-align: center;
        }

        .banner-wrapper {
            width: 95%;
            padding: 20px;
        }

        .main-text {
            font-size: clamp(1.2rem, 4vw, 2.5rem);
            font-weight: 700;
            color: var(--text-color);
            line-height: 1.2;
        }

        .count-number {
            display: block;
            font-size: clamp(2.5rem, 10vw, 5rem);
            color: var(--highlight-color);
            font-weight: 800;
            margin: 10px 0;
        }

        .sub-text {
            display: block;
            font-size: 0.8em;
            opacity: 0.9;
        }
    </style>
</head>
<body>

    <div class="banner-wrapper">
        <div class="main-text">
            <span class="count-number" id="counter">0</span>
            <span class="sub-text">الديون</span>
        </div>
    </div>

    <script>
        // ضع رابط الـ Web App الذي نسخته من جوجل شيت هنا
        const webAppUrl = "https://script.google.com/macros/s/AKfycbyIawYgmY4v7lVx9KhDzdyLBFZSXVQiT_kpg7mOWcEzquGIiDnlT5pnrMxXGxaaT5yClg/exec";

        async function fetchValueAndRun() {
            const counterElement = document.getElementById('counter');
            
            try {
                // جلب القيمة من جوجل شيت
                const response = await fetch(webAppUrl);
                const data = await response.text();
                const targetValue = parseInt(data);

                if (!isNaN(targetValue)) {
                    runCounter(targetValue);
                } else {
                    counterElement.innerText = "Error";
                }
            } catch (error) {
                console.error("Error fetching data:", error);
                counterElement.innerText = "!!";
            }
        }

        function runCounter(target) {
            const duration = 2000; 
            const counterElement = document.getElementById('counter');
            let start = 0;
            const startTime = performance.now();

            function update(currentTime) {
                const elapsed = currentTime - startTime;
                const progress = Math.min(elapsed / duration, 1);
                
                // معادلة لجعل الحركة تبدو أكثر سلاسة (Ease Out)
                const currentCount = Math.floor(progress * target);
                
                counterElement.innerText = currentCount + "";

                if (progress < 1) {
                    requestAnimationFrame(update);
                } else {
                    counterElement.innerText = target + "";
                }
            }
            requestAnimationFrame(update);
        }

        window.onload = fetchValueAndRun;
    </script>

</body>
</html>
